# ═══════════════════════════════════════════════════════════════
#  CITROËN BERLINGO — Variables de entorno (formularios + seguridad)
# ═══════════════════════════════════════════════════════════════
#  Copia este archivo como ".env" en la raíz del proyecto,
#  completa los valores y ejecuta: npm run build
# ═══════════════════════════════════════════════════════════════


# ── ZAPIER WEBHOOKS ──────────────────────────────────────────
#
#  Cómo obtener las URLs:
#  1. Ve a https://zapier.com → Create Zap
#  2. Trigger: "Webhooks by Zapier" → Event: "Catch Hook"
#  3. Copia la URL generada (empieza por https://hooks.zapier.com/...)
#  4. Pégala abajo según el formulario correspondiente
#
#  Puedes usar la misma URL para los 3 formularios y diferenciarlos
#  por el campo "tipo" que envía el handler ("cotizacion" | "cita" | "repuestos").
#  O tener Zaps separados para mejor organización.
#
#  Campos que llegan a Zapier por formulario:
#
#  [cotizacion] — Formulario principal Hero:
#    tipo, firstname, lastname, phone, email, city, version, message,
#    recaptcha_token, timestamp, page_url
#
#  [cita] — Agenda tu cita (Posventa):
#    tipo, firstname, lastname, phone, plate, city,
#    recaptcha_token, timestamp, page_url
#
#  [repuestos] — Pregunta tus repuestos (Posventa):
#    tipo, firstname, lastname, email, phone, part,
#    recaptcha_token, timestamp, page_url

PUBLIC_ZAPIER_WEBHOOK_COTIZACION=https://hooks.zapier.com/hooks/catch/XXXXXXX/YYYYYYY/
PUBLIC_ZAPIER_WEBHOOK_CITA=https://hooks.zapier.com/hooks/catch/XXXXXXX/YYYYYYY/
PUBLIC_ZAPIER_WEBHOOK_REPUESTOS=https://hooks.zapier.com/hooks/catch/XXXXXXX/YYYYYYY/


# ── GOOGLE reCAPTCHA ─────────────────────────────────────────
#
#  CLAVES NECESARIAS — Google genera dos por dominio:
#
#  ① SITE KEY  (pública / "clave del sitio")
#     → Se incluye en el HTML del navegador. Es seguro que sea visible.
#     → Va en PUBLIC_RECAPTCHA_SITE_KEY (abajo).
#
#  ② SECRET KEY (privada / "clave secreta")
#     → NUNCA va en este .env ni en el código del sitio.
#     → Se pega directamente dentro del paso "Code by Zapier" (ver abajo).
#     → Si la pones aquí como PUBLIC_, quedará expuesta en el HTML.
#
#  Cómo obtener ambas:
#  1. Ve a https://www.google.com/recaptcha/admin/create
#  2. Elige el tipo (v2 o v3, según PUBLIC_RECAPTCHA_VERSION abajo)
#  3. Agrega tu dominio de producción
#  4. Google te muestra "Site key" → PUBLIC_RECAPTCHA_SITE_KEY
#              y "Secret key" → la copias solo en Zapier
#
#  Versión a usar:
#  - v3 (recomendado): invisible, da un score 0-1 de probabilidad de bot.
#  - v2: muestra el checkbox "No soy un robot" visible en cada formulario.
#
PUBLIC_RECAPTCHA_VERSION=v3       # 'v2' o 'v3'
PUBLIC_RECAPTCHA_SITE_KEY=        # Site Key (pública)

#
#  Verificación en Zapier — paso "Code by Zapier" (Python):
#  ┌──────────────────────────────────────────────────────────────┐
#  │ import requests                                              │
#  │ token  = input_data.get('recaptcha_token', '')              │
#  │ secret = 'PEGA_AQUI_TU_SECRET_KEY'  # ← solo acá, nunca en .env │
#  │ r = requests.post(                                           │
#  │   'https://www.google.com/recaptcha/api/siteverify',        │
#  │   data={'secret': secret, 'response': token})               │
#  │ result = r.json()                                            │
#  │ score  = result.get('score', 0)   # solo relevante en v3    │
#  │ output = {                                                   │
#  │   'valid': result.get('success', False),                    │
#  │   'score': score,                                            │
#  │   'is_human': result.get('success') and score >= 0.5,       │
#  │ }                                                            │
#  └──────────────────────────────────────────────────────────────┘
#  Luego agrega un paso "Filter by Zapier": continúa solo si is_human = True.
#  (Para v2: score siempre es 0, usa solo valid = True como condición)


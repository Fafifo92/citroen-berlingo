---
// Performance.astro - Sección Problema → Solución
import ResponsiveImage from './ResponsiveImage.astro';
const base = import.meta.env.BASE_URL;

const painPoints = [
  {
    icon: 'box',
    question: '¿Poco espacio de carga?',
  },
  {
    icon: 'fuel',
    question: '¿Alto consumo de combustible?',
  },
  {
    icon: 'seat',
    question: '¿Incomodidad para jornadas largas?',
  },
  {
    icon: 'wrench',
    question: '¿Mal Servicio Posventa?',
  },
];
---

<section id="problem-solution" class="py-24 bg-[#F8F9FA]">
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16" data-reveal="fade-up">
      <span class="inline-block px-3 py-1 mb-6 text-[10px] font-bold uppercase tracking-[0.15em] text-[#DA291C] border border-[#DA291C]/30 bg-[#DA291C]/5">
        El desafío de tu negocio
      </span>
      <h2 class="text-[clamp(2rem,4vw,3rem)] leading-[1.1] font-bold text-[#3B3938] mb-6">
        Tu negocio no solo necesita moverse,<br/>
        <span class="text-[#646464] font-normal">también necesita avanzar</span>
      </h2>
    </div>

    <!-- Pain Points Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
      {painPoints.map((pain, i) => (
        <div class="bg-white border border-[#E7E7E7] p-6 rounded-lg text-center hover:border-[#DA291C]/30 transition-colors duration-300 group" data-reveal="fade-up" style={`--reveal-delay: ${i * 0.1}s`}>
          <div class="w-14 h-14 mx-auto rounded-full bg-[#DA291C]/[0.06] flex items-center justify-center mb-4">
            {pain.icon === 'box' && (
              <svg class="w-7 h-7 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            )}
            {pain.icon === 'fuel' && (
              <svg class="w-7 h-7 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/><path d="M15 10h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2v0"/><path d="M3 22h12"/><rect x="6" y="10" width="4" height="4"/></svg>
            )}
            {pain.icon === 'seat' && (
              <svg class="w-7 h-7 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 36V22a10 10 0 0 1 20 0v14"/><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            )}
            {pain.icon === 'wrench' && (
              <svg class="w-7 h-7 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            )}
          </div>
          <p class="text-[15px] font-bold text-[#3B3938]">{pain.question}</p>
        </div>
      ))}
    </div>

    <!-- Solution Box -->
    <div class="relative bg-[#3B3938] rounded-lg overflow-hidden" data-reveal="fade-up" style="--reveal-delay: 0.1s">
      <div class="absolute inset-0 bg-gradient-to-r from-[#DA291C]/10 to-transparent pointer-events-none"></div>
      <div class="grid lg:grid-cols-[2fr_3fr] gap-8 items-center relative z-10">

        <!-- Text -->
        <div class="p-10 lg:p-14">
          <div class="w-16 h-16 rounded-full bg-[#DA291C] flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold text-white leading-[1.15] mb-4">
            Citroën Berlingo<br/>
            <span class="text-[#DA291C]">diseñada para trabajar contigo</span>
          </h3>
          <p class="text-[16px] text-white/70 leading-relaxed max-w-lg">
            La Berlingo Van resuelve cada uno de estos desafíos con capacidad de carga líder, eficiencia superior, confort real para jornadas largas y un servicio posventa que no te deja parado.
          </p>
          <a href="#features" class="btn-primary mt-8 inline-flex">Conoce los beneficios</a>
        </div>

        <!-- Image -->
        <div class="h-[300px] lg:h-full min-h-[380px]">
          <ResponsiveImage
            src="FOTOS BERLINGO/PHOTO- foto frontal desde un lado derecho.jpg"
            alt="Citroën Berlingo Van - La solución para tu negocio"
            class="w-full h-full object-cover"
            sizes="(min-width: 1024px) 60vw, 100vw"
          />
        </div>
      </div>
    </div>

  </div>
</section>

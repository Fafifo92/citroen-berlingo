---
// LeadForm.astro — Lead capture form (Stellantis style)
---

<section class="py-20 bg-[#F5F6F7]" id="lead-form">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Info Column -->
      <div>
        <span
          class="inline-block px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.15em] text-[#DA291C] border border-[#DA291C] mb-6"
        >
          Solicita Información
        </span>
        <h2
          class="text-[clamp(1.75rem,4vw,2.25rem)] text-[#3B3938] uppercase font-bold leading-[1.1] mb-4"
        >
          ¿Interesado en la<br />Berlingo Van?
        </h2>
        <p class="text-[15px] text-[#646464] leading-[1.65] mb-8 max-w-[420px]">
          Completa el formulario y uno de nuestros asesores comerciales se
          pondrá en contacto contigo para brindarte una cotización
          personalizada.
        </p>

        <!-- Benefits -->
        <div class="flex flex-col gap-3.5">
          <div class="flex items-center gap-3 text-sm text-[#3B3938] font-bold">
            <svg
              class="w-5 h-5 text-[#DA291C] shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Cotización sin compromiso</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-[#3B3938] font-bold">
            <svg
              class="w-5 h-5 text-[#DA291C] shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Respuesta en 24 horas</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-[#3B3938] font-bold">
            <svg
              class="w-5 h-5 text-[#DA291C] shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Prueba de manejo disponible</span>
          </div>
        </div>
      </div>

      <!-- Form Column -->
      <form
        class="bg-white p-8 md:p-10 border border-[#E7E7E7] rounded-lg"
        id="contact-form"
        novalidate
      >
        <!-- Names -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label
              for="firstname"
              class="block text-[13px] font-bold uppercase tracking-[0.05em] text-[#3B3938] mb-1.5"
            >
              Nombre
            </label>
            <input
              type="text"
              id="firstname"
              name="firstname"
              class="form-input"
              placeholder="Ej. Juan"
              required
              autocomplete="given-name"
            />
          </div>
          <div>
            <label
              for="lastname"
              class="block text-[13px] font-bold uppercase tracking-[0.05em] text-[#3B3938] mb-1.5"
            >
              Apellido
            </label>
            <input
              type="text"
              id="lastname"
              name="lastname"
              class="form-input"
              placeholder="Ej. Pérez"
              required
              autocomplete="family-name"
            />
          </div>
        </div>

        <!-- Contact Info (Email & Phone) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label
              for="email"
              class="block text-[13px] font-bold uppercase tracking-[0.05em] text-[#3B3938] mb-1.5"
            >
              Correo
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="Ej. juan@empresa.com"
              required
              autocomplete="email"
            />
          </div>
          <div>
            <label
              for="phone"
              class="block text-[13px] font-bold uppercase tracking-[0.05em] text-[#3B3938] mb-1.5"
            >
              Teléfono
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              placeholder="Ej. +52 55 1234 5678"
              required
              autocomplete="tel"
            />
          </div>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-primary w-full mt-2" id="submit-btn">
          Solicitar Cotización
        </button>

        <p class="text-xs text-[#ababab] text-center mt-5 leading-relaxed">
          Al enviar este formulario, aceptas nuestra
          <a
            href="#"
            class="text-[#DA291C] underline underline-offset-2 hover:text-[#B82118]"
            >Política de Privacidad</a
          >
          y el tratamiento de tus datos.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const btn = document.getElementById("submit-btn") as HTMLButtonElement;
    if (btn) {
      btn.textContent = "¡Enviado con éxito!";
      btn.style.backgroundColor = "#3B3938";
      btn.disabled = true;
    }
    setTimeout(() => {
      form.reset();
      if (btn) {
        btn.textContent = "Solicitar Cotización";
        btn.style.backgroundColor = "";
        btn.disabled = false;
      }
    }, 3000);
  });
</script>

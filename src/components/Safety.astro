---
// Safety.astro — Servicio Posventa section
const base = import.meta.env.BASE_URL;

const services = [
  {
    icon: 'tools',
    title: 'Respaldo real para tu operación',
    items: [
      'Red de talleres especializados',
      'Técnicos certificados',
      'Atención prioritaria para vehículos de trabajo',
    ],
  },
  {
    icon: 'parts',
    title: 'Repuestos disponibles',
    items: [
      'Stock de repuestos originales',
      'Menores tiempos de espera',
      'Soporte continuo para tu operación',
    ],
  },
  {
    icon: 'maintenance',
    title: 'Mantenimiento eficiente',
    items: [
      'Planes de mantenimiento programado',
      'Optimización de tiempos en taller',
      'Mayor vida útil del vehículo',
    ],
  },
  {
    icon: 'support',
    title: 'Acompañamiento constante',
    items: [
      'Asesoría posventa personalizada',
      'Seguimiento de tu vehículo',
      'Soporte para flotas y empresas',
    ],
  },
];
---

<section class="py-24 bg-[#111111] text-white" id="posventa">
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-3 py-1 mb-6 text-[10px] font-bold uppercase tracking-[0.15em] text-white border border-white/30 rounded-sm">
        Servicio Posventa
      </span>
      <h2 class="text-[clamp(2rem,4vw,3rem)] leading-[1.1] font-bold text-white mb-4">
        Tu negocio no se detiene,<br/>
        <span class="text-[#DA291C]">tu Berlingo tampoco</span>
      </h2>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {services.map((service) => (
        <div class="bg-white/5 border border-white/10 rounded-lg p-7 hover:border-[#DA291C]/40 transition-colors duration-300 group">
          <!-- Icon -->
          <div class="w-12 h-12 rounded-full bg-[#DA291C]/10 flex items-center justify-center mb-5">
            {service.icon === 'tools' && (
              <svg class="w-6 h-6 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            )}
            {service.icon === 'parts' && (
              <svg class="w-6 h-6 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            )}
            {service.icon === 'maintenance' && (
              <svg class="w-6 h-6 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            )}
            {service.icon === 'support' && (
              <svg class="w-6 h-6 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            )}
          </div>

          <h3 class="text-[15px] font-bold text-white uppercase mb-4">{service.title}</h3>
          <ul class="space-y-2.5">
            {service.items.map((item) => (
              <li class="flex items-start gap-2.5 text-[13px] text-white/60 leading-relaxed">
                <svg class="w-3.5 h-3.5 text-[#DA291C] mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Dual Form Area: Agenda cita + Pregunta repuestos -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Agenda Cita -->
      <div class="bg-white/5 border border-white/10 rounded-lg p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-full bg-[#DA291C] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div>
            <h3 class="text-[18px] font-bold text-white uppercase leading-tight">Agenda tu cita</h3>
            <p class="text-[12px] text-white/50">Mantenimiento y servicio técnico</p>
          </div>
        </div>
        <form class="posventa-form" data-form="cita" novalidate>
          <div class="grid grid-cols-2 gap-3 mb-3">
            <input type="text" name="firstname" class="pv-input" placeholder="Nombre" required />
            <input type="text" name="lastname" class="pv-input" placeholder="Apellido" required />
          </div>
          <input type="tel" name="phone" class="pv-input mb-3" placeholder="Teléfono" required />
          <input type="text" name="plate" class="pv-input mb-3" placeholder="Placa del vehículo (opcional)" />
          <input type="text" name="city" class="pv-input mb-4" placeholder="Ciudad" required />
          <button type="submit" class="btn-primary w-full">Agendar Cita</button>
        </form>
      </div>

      <!-- Pregunta Repuestos -->
      <div class="bg-white/5 border border-white/10 rounded-lg p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 border border-white/20">
            <svg class="w-5 h-5 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 10v6m11-11h-6M7 12H1m16.5-6.5l-4.24 4.24M6.74 17.26l-4.24 4.24m15 0l-4.24-4.24M6.74 6.74L2.5 2.5"/></svg>
          </div>
          <div>
            <h3 class="text-[18px] font-bold text-white uppercase leading-tight">Pregunta tus repuestos</h3>
            <p class="text-[12px] text-white/50">Consulta disponibilidad y cotización</p>
          </div>
        </div>
        <form class="posventa-form" data-form="repuestos" novalidate>
          <div class="grid grid-cols-2 gap-3 mb-3">
            <input type="text" name="firstname" class="pv-input" placeholder="Nombre" required />
            <input type="text" name="lastname" class="pv-input" placeholder="Apellido" required />
          </div>
          <input type="email" name="email" class="pv-input mb-3" placeholder="Correo" required />
          <input type="tel" name="phone" class="pv-input mb-3" placeholder="Teléfono" required />
          <textarea name="part" rows="2" class="pv-input !h-auto py-3 mb-4" placeholder="¿Qué repuesto necesitas?" required></textarea>
          <button type="submit" class="btn-outline w-full">Solicitar Repuesto</button>
        </form>
      </div>

    </div>

  </div>
</section>

<style>
  .pv-input {
    width: 100%;
    height: 44px;
    padding: 0 14px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .pv-input::placeholder { color: rgba(255, 255, 255, 0.35); }
  .pv-input:focus {
    border-color: rgba(255, 255, 255, 0.5);
    background: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  import { submitForm } from './form-handler';
  import type { FormType } from './form-handler';

  document.querySelectorAll<HTMLFormElement>('form.posventa-form').forEach((form) => {
    const formType = form.dataset.form as FormType;
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (!btn) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      await submitForm(form, formType, btn);
    });
  });
</script>

---
// Gallery.astro — Bento grid gallery with lightbox support
const base = import.meta.env.BASE_URL;

const images = [
  {
    src: `${base}images/gallery-exterior.png`,
    alt: "Citroën Berlingo Van - Vista exterior lateral",
    label: "Exterior",
    wide: true,
  },
  {
    src: `${base}images/gallery-cargo.png`,
    alt: "Citroën Berlingo Van - Puertas traseras abiertas y zona de carga",
    label: "Carga",
    wide: false,
  },
  {
    src: `${base}images/gallery-cabin.png`,
    alt: "Citroën Berlingo Van - Interior de cabina y tablero",
    label: "Cabina",
    wide: false,
  },
];
---

<section class="py-20 bg-[#F5F6F7]" id="gallery">
  <div class="max-w-[1200px] mx-auto px-6">
    <h2
      class="text-[clamp(1.75rem,4vw,2.5rem)] text-[#3B3938] text-center mb-3 uppercase font-bold"
    >
      Galería
    </h2>
    <p
      class="text-[17px] text-[#646464] text-center max-w-[600px] mx-auto mb-12 leading-relaxed font-normal normal-case"
    >
      Descubre cada ángulo de la nueva Berlingo Van. Haz clic en cualquier
      imagen para ampliarla.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {
        images.map((img) => (
          <figure
            class={`relative overflow-hidden group ${img.wide ? "sm:col-span-2" : ""}`}
          >
            <div
              class={`relative overflow-hidden rounded-lg bg-[#E7E7E7] ${img.wide ? "aspect-[21/9] sm:aspect-[21/9]" : "aspect-[16/10]"} lg:aspect-auto lg:h-[280px]`}
            >
              <img
                src={img.src}
                alt={img.alt}
                data-lightbox
                data-label={img.label}
                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105 cursor-zoom-in"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex items-end justify-between p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
                <span class="text-[13px] font-bold uppercase tracking-[0.12em] text-white px-4 py-1.5 border border-white/40">
                  {img.label}
                </span>
                <svg
                  class="w-6 h-6 text-white/70"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="11" cy="11" r="8" />
                  <line x1="21" y1="21" x2="16.65" y2="16.65" />
                  <line x1="11" y1="8" x2="11" y2="14" />
                  <line x1="8" y1="11" x2="14" y2="11" />
                </svg>
              </div>
            </div>
          </figure>
        ))
      }
    </div>
  </div>
</section>

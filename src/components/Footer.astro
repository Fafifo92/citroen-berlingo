          </g>
        </svg>
        <span class="text-[14px] font-bold tracking-[0.14em] text-white/80 group-hover:text-[#DA291C] transition-colors duration-300" style="font-family: 'Citroen Type', sans-serif;">CITROËN</span>
      </div>
      <p class="text-sm text-white/40 max-w-[280px]">Berlingo Van — Diseñada para mover tu negocio.</p>
    </div>

    <!-- Links -->
    <div class="grid grid-cols-2 gap-8">
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.15em] text-white/35 mb-4">Legal</h4>
        <a href="#" class="block text-sm text-white/60 mb-2.5 hover:text-[#DA291C] transition-colors">Aviso Legal</a>
        <a href="#" class="block text-sm text-white/60 mb-2.5 hover:text-[#DA291C] transition-colors">Política de Privacidad</a>
        <a href="#" class="block text-sm text-white/60 mb-2.5 hover:text-[#DA291C] transition-colors">Política de Cookies</a>
      </div>
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.15em] text-white/35 mb-4">Contacto</h4>
        <a href="#lead-form" class="block text-sm text-white/60 mb-2.5 hover:text-[#DA291C] transition-colors">Solicitar Cotización</a>
        <a href="tel:+525512345678" class="block text-sm text-white/60 mb-2.5 hover:text-[#DA291C] transition-colors">+52 55 1234 5678</a>
        <a href="mailto:info@citroen.com" class="block text-sm text-white/60 mb-2.5 hover:text-[#DA291C] transition-colors">info@citroen.com</a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/8 py-6">
    <div class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row md:justify-between md:items-center gap-2">
      <p class="text-xs text-white/30">&copy; {year} Citroën. Todos los derechos reservados.</p>
      <p class="text-[11px] text-white/25">
        Las fotografías e información presentadas son de carácter referencial. Consulta con tu concesionario autorizado.
      </p>
    </div>
  </div>
</footer>

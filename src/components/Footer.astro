    <!-- Brand -->
    <div>
      <div class="flex items-center gap-2 mb-3 group w-fit">
        <svg
          class="h-7 w-auto text-white/80 group-hover:text-[#DA291C] transition-colors duration-300 logo-chevron"
          viewBox="0 0 245 306"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <g transform="translate(0,306) scale(0.1,-0.1)" fill="currentColor" stroke="none">

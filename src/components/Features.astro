---
// Features.astro — Responsive 3-column advantages grid (Stellantis style)
const features = [
  {
    icon: 'cargo',
    title: 'Capacidad de Carga',
    subtitle: 'Espacio Optimizado',
    description: 'Hasta 4.4 m³ de volumen de carga útil. Diseñada para maximizar cada centímetro de espacio disponible, adaptándose a las necesidades de tu negocio.',
    stats: [
      { value: '4.4', unit: 'm³', label: 'Volumen' },
      { value: '1000', unit: 'kg', label: 'Carga útil' },
    ],
  },
  {
    icon: 'engine',
    title: 'Rendimiento',
    subtitle: 'Motores Eficientes',
    description: 'Motorización diésel y gasolina de última generación. Menor consumo, menores emisiones y máxima potencia para cada kilómetro recorrido.',
    stats: [
      { value: '5.1', unit: 'L/100km', label: 'Consumo' },
      { value: '130', unit: 'CV', label: 'Potencia' },
    ],
  },
  {
    icon: 'comfort',
    title: 'Confort Citroën',
    subtitle: 'Cabina Ergonómica',
    description: 'Interior premium con asientos ergonómicos, pantalla táctil de 10" y todos los sistemas de asistencia a la conducción para tus jornadas más largas.',
    stats: [
      { value: '10', unit: '"', label: 'Pantalla' },
      { value: '16', unit: 'ADAS', label: 'Ayudas' },
    ],
  },
];
---

<section class="py-20 bg-white" id="features">
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-3 py-1 mb-6 text-[10px] font-bold uppercase tracking-[0.15em] text-[#DA291C] border border-[#DA291C] border-opacity-30 border-solid rounded-sm">Beneficios Clave</span>
      <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] font-bold text-[#3B3938] mb-6">
        Potencia Tu<br class="md:hidden"/> Productividad.
      </h2>
      <p class="text-[1.125rem] text-[#646464] leading-relaxed">
        La Berlingo Van combina capacidad excepcional, motores ultrarrentables y un confort digno de los mejores turismos de Citroën.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {features.map((feature) => (
        <article class="border border-[#E7E7E7] rounded-lg p-8 transition-all duration-300 hover:border-[#DA291C]/30 hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)] group relative overflow-hidden">
          <!-- Top accent bar on hover -->
          <div class="absolute top-0 left-0 w-full h-[3px] bg-[#DA291C] scale-x-0 origin-left transition-transform duration-300 group-hover:scale-x-100"></div>

          <!-- Icon -->
          <div class="w-14 h-14 flex items-center justify-center bg-[rgba(218,41,28,0.06)] mb-6">
            {feature.icon === 'cargo' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="6" y="14" width="28" height="22" rx="1"/>
                <path d="M34 20h6l4 8v8h-10"/>
                <circle cx="14" cy="38" r="3"/>
                <circle cx="38" cy="38" r="3"/>
                <path d="M17 36h17"/>
                <line x1="6" y1="24" x2="34" y2="24"/>
              </svg>
            )}
            {feature.icon === 'engine' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="24" cy="24" r="16"/>
                <circle cx="24" cy="24" r="6"/>
                <path d="M24 8v6M24 34v6M8 24h6M34 24h6"/>
                <path d="M13 13l4.5 4.5M30.5 30.5l4.5 4.5M13 35l4.5-4.5M30.5 17.5l4.5-4.5"/>
              </svg>
            )}
            {feature.icon === 'comfort' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 36V22a10 10 0 0 1 20 0v14"/>
                <path d="M10 36h28"/>
                <path d="M18 28h12"/>
                <path d="M20 24h8"/>
                <circle cx="24" cy="16" r="2"/>
                <path d="M12 40h24"/>
              </svg>
            )}
          </div>

          <!-- Content -->
          <span class="block text-[11px] font-bold uppercase tracking-[0.15em] text-[#DA291C] mb-2">{feature.subtitle}</span>
          <h3 class="text-xl text-[#3B3938] uppercase font-bold mb-3">{feature.title}</h3>
          <p class="text-[15px] text-[#646464] leading-[1.65] mb-6">{feature.description}</p>

          <!-- Stats -->
          <div class="flex gap-8 pt-5 border-t border-[#E7E7E7]">
            {feature.stats.map((stat) => (
              <div class="flex flex-col">
                <span class="text-2xl font-bold text-[#3B3938] leading-none">
                  {stat.value}<small class="text-xs font-normal text-[#646464] ml-0.5">{stat.unit}</small>
                </span>
                <span class="text-xs text-[#ababab] uppercase tracking-[0.06em] mt-1">{stat.label}</span>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
// Features.astro — 4 Beneficios principales del documento
const features = [
  {
    icon: 'cargo',
    title: 'Capacidad que optimiza tu operación',
    items: [
      'Hasta 4,4 m³ de volumen de carga',
      'Longitud de carga hasta 3,44 m',
      'Ideal para logística, distribución y negocio propio',
    ],
  },
  {
    icon: 'engine',
    title: 'Ahorro y eficiencia',
    items: [
      'Motor turbodiésel 1.5L de máxima eficiencia',
      'Más espacio, más ingresos por viaje',
      'Perfecta para largas jornadas de trabajo',
    ],
  },
  {
    icon: 'comfort',
    title: 'Confort como un carro',
    items: [
      'Aire acondicionado digital',
      'Asientos ergonómicos',
      'Tecnología para el día a día',
    ],
  },
  {
    icon: 'tech',
    title: 'Tecnología para el día a día',
    items: [
      'Pantalla táctil de 10"',
      'Conectividad Bluetooth / multimedia',
      'Sistemas de asistencia a la conducción',
    ],
  },
];
---

<section class="py-20 bg-white" id="features">
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-3 py-1 mb-6 text-[10px] font-bold uppercase tracking-[0.15em] text-[#DA291C] border border-[#DA291C] border-opacity-30 border-solid rounded-sm">Beneficios Principales</span>
      <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] font-bold text-[#3B3938] mb-6">
        Todo lo que tu negocio<br class="md:hidden"/> necesita para crecer
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature) => (
        <article class="border border-[#E7E7E7] rounded-lg p-8 transition-all duration-300 hover:border-[#DA291C]/30 hover:shadow-[0_4px_20px_rgba(0,0,0,0.06)] group relative overflow-hidden">
          <!-- Top accent bar on hover -->
          <div class="absolute top-0 left-0 w-full h-[3px] bg-[#DA291C] scale-x-0 origin-left transition-transform duration-300 group-hover:scale-x-100"></div>

          <!-- Icon -->
          <div class="w-14 h-14 flex items-center justify-center bg-[rgba(218,41,28,0.06)] rounded-full mb-6">
            {feature.icon === 'cargo' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="6" y="14" width="28" height="22" rx="1"/>
                <path d="M34 20h6l4 8v8h-10"/>
                <circle cx="14" cy="38" r="3"/>
                <circle cx="38" cy="38" r="3"/>
                <path d="M17 36h17"/>
                <line x1="6" y1="24" x2="34" y2="24"/>
              </svg>
            )}
            {feature.icon === 'engine' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 22V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"/>
                <path d="M15 10h2a2 2 0 0 1 2 2v2a2 2 0 0 0 2 2v0"/>
                <path d="M3 22h12"/>
                <rect x="6" y="10" width="4" height="4"/>
              </svg>
            )}
            {feature.icon === 'comfort' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/>
              </svg>
            )}
            {feature.icon === 'tech' && (
              <svg class="w-7 h-7 text-[#DA291C]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            )}
          </div>

          <!-- Content -->
          <h3 class="text-[16px] text-[#3B3938] uppercase font-bold mb-4 leading-tight">{feature.title}</h3>

          <!-- Feature List -->
          <ul class="space-y-3">
            {feature.items.map((item) => (
              <li class="flex items-start gap-2.5 text-[14px] text-[#646464] leading-relaxed">
                <svg class="w-4 h-4 text-[#DA291C] mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

---
// Technology.astro - Red de Concesionarios y Talleres
const dealers = [
  { name: 'Country Trucks Barranquilla', address: 'Calle 30 19-55', city: 'Barranquilla' },
  { name: 'Inchcape Retail Américas', address: 'Av. De las Américas No. 39-63', city: 'Bogotá' },
  { name: 'Inchcape Retail Fontibón', address: 'Fontibón Diagonal 16 No. 96i-15', city: 'Bogotá' },
  { name: 'Truck Nation Bogotá', address: 'AK 86 # 11-40', city: 'Bogotá' },
  { name: 'Inchcape Retail Chía', address: 'Autopista norte km 20 costado oriental', city: 'Chía' },
  { name: 'Vehidiesel Cartagena', address: 'Diagonal 21 #45a-112 El Bosque', city: 'Cartagena' },
  { name: 'Truck Nation Itagüí', address: 'Cra 42 No. 46-130 Autopista Sur', city: 'Itagüí' },
  { name: 'Pacífico Motors Cali', address: 'Calle 15 # 27A-176 Bloque 7C', city: 'Cali' },
  { name: 'Pacífico Motors Yumbo', address: 'Autopista Sur Oriental calle 10 # 46-90', city: 'Yumbo' },
  { name: 'Vehidiesel Bucaramanga', address: 'Calle 70 # 32W-92 KM 4 Vía Girón', city: 'Bucaramanga' },
  { name: 'Andinautos Pereira', address: 'Avenida 30 de agosto # 33-09', city: 'Pereira' },
  { name: 'Country Trucks Tunja', address: 'Calle 75 # 3E-88', city: 'Tunja' },
  { name: 'Alcalá Villavicencio', address: 'Calle 2 #33-79 Anillo Vial', city: 'Villavicencio' },
  { name: 'Fersautos Cúcuta', address: 'Avenida 7 # 8N-58 Barrio Sevilla', city: 'Cúcuta' },
].map(d => ({
  ...d,
  mapsUrl: `https://www.google.com/maps/search/${encodeURIComponent(d.name + ' ' + d.address + ' ' + d.city + ' Colombia')}`,
}));
---

<section id="dealers" class="py-24 bg-[#F8F9FA]">
  <div class="max-w-[1200px] mx-auto px-6">

    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-3 py-1 mb-6 text-[10px] font-bold uppercase tracking-[0.15em] text-[#DA291C] border border-[#DA291C]/30 bg-[#DA291C]/5">
        Red Autorizada
      </span>
      <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] font-bold text-[#3B3938] mb-4">
        Red de Concesionarios y<br/>
        <span class="text-[#646464] font-normal">Talleres Citroën Vans</span>
      </h2>
    </div>

    <!-- Dealers Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {dealers.map((dealer) => (
        <a
          href={dealer.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white border border-[#E7E7E7] rounded-lg p-5 hover:border-[#DA291C]/40 hover:shadow-md transition-all duration-300 group block"
          aria-label={`Ver ${dealer.name} en Google Maps`}
        >
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 shrink-0 rounded-full bg-[#DA291C]/[0.06] flex items-center justify-center mt-0.5 group-hover:bg-[#DA291C]/15 transition-colors">
              <svg class="w-4 h-4 text-[#DA291C]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-[14px] font-bold text-[#3B3938] mb-1 group-hover:text-[#DA291C] transition-colors leading-tight">{dealer.name}</h3>
              <p class="text-[12px] text-[#646464] leading-relaxed">{dealer.address}</p>
              <p class="text-[11px] text-[#DA291C]/70 font-bold uppercase tracking-wide mt-1 opacity-0 group-hover:opacity-100 transition-opacity">Ver en Maps →</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="#hero" class="btn-primary">Cotiza tu Berlingo Van</a>
    </div>
  </div>
</section>

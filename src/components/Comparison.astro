---
// Comparison.astro — Versiones: 1 puerta lateral vs doble puerta lateral
import ResponsiveImage from './ResponsiveImage.astro';
const base = import.meta.env.BASE_URL;

const models = [
  {
    name: 'Berlingo 1 Puerta Lateral',
    description: 'Configuración estándar con una puerta lateral corrediza. Ideal para operaciones de carga y descarga en espacios reducidos.',
    image: 'FOTOS BERLINGO/PHOTO- Vista lateral.jpg',
    recommended: false,
  },
  {
    name: 'Berlingo Doble Puerta Lateral',
    description: 'Doble acceso lateral para máxima versatilidad en carga y descarga, optimizando los tiempos de tu operación.',
    image: 'FOTOS BERLINGO/persona sacando cargamento por la doblepuerta trasera de la berlingo.jpg',
    recommended: true,
  },
];

const colors = [
  { name: 'Blanco', hex: '#FFFFFF', border: true },
];
---

<section class="py-20 bg-white" id="comparison">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-3 py-1 mb-6 text-[10px] font-bold uppercase tracking-[0.15em] text-[#DA291C] border border-[#DA291C] border-opacity-30 border-solid rounded-sm">Versiones</span>
      <h2 class="text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] font-bold text-[#3B3938] mb-6">
        Elige la Berlingo que mejor<br class="md:hidden"/> se adapta a tu operación
      </h2>
    </div>

    <!-- Models Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {models.map((model) => (
        <div class={`border rounded-lg overflow-hidden transition-all duration-300 hover:shadow-lg ${model.recommended ? 'border-[#DA291C] ring-2 ring-[#DA291C]/15 relative' : 'border-[#E7E7E7]'}`}>
          {model.recommended && (
            <div class="absolute top-4 right-4 z-10">
              <span class="px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white bg-[#DA291C] rounded-full">Recomendado</span>
            </div>
          )}

          <!-- Image -->
          <div class="h-[220px] bg-[#F5F6F7] flex items-center justify-center relative overflow-hidden">
            <ResponsiveImage
              src={model.image}
              alt={model.name}
              class="w-full h-full object-cover"
              sizes="(min-width: 768px) 50vw, 100vw"
            />
          </div>

          <!-- Content -->
          <div class="p-8">
            <h3 class="text-xl font-bold text-[#3B3938] uppercase mb-3">{model.name}</h3>
            <p class="text-[14px] text-[#646464] leading-relaxed mb-6">{model.description}</p>
            <a href="#hero" class={`w-full ${model.recommended ? 'btn-primary' : 'btn-outline-dark'}`}>
              Cotizar
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Colors -->
    <div class="text-center mb-12">
      <h3 class="text-lg font-bold text-[#3B3938] uppercase mb-4">Colores disponibles</h3>
      <div class="flex justify-center gap-4">
        {colors.map((color) => (
          <div class="flex flex-col items-center gap-2">
            <div class={`w-12 h-12 rounded-full ${color.border ? 'border-2 border-[#E7E7E7]' : ''}`} style={`background-color: ${color.hex}`}></div>
            <span class="text-[13px] text-[#646464] font-bold">{color.name}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Dimensions Box (estilo ficha con silueta + medidas) -->
    <div class="bg-white border border-[#E7E7E7] rounded-lg p-8 lg:p-10">
      <h3 class="text-lg font-bold text-[#3B3938] uppercase mb-6 text-center">Dimensiones exteriores</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">

        <!-- Silueta -->
        <div class="flex items-center justify-center">
          <img
            src={`${base}images/PNG/Iconos%20de%20seguridad/BERLINGO%20K9-%20fondo%20transparente.png`}
            alt="Silueta Citroën Berlingo"
            class="max-h-[180px] w-auto object-contain"
            loading="lazy"
          />
        </div>

        <!-- Medidas -->
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-[#F8F9FA] border border-[#E7E7E7] rounded-md py-5 px-3 text-center">
            <p class="text-[11px] text-[#646464] uppercase tracking-[0.08em] font-bold mb-2">Longitud total</p>
            <div class="text-[1.5rem] md:text-[1.75rem] font-bold text-[#DA291C] leading-none">4.753<span class="text-sm text-[#3B3938] ml-1">mm</span></div>
          </div>
          <div class="bg-[#F8F9FA] border border-[#E7E7E7] rounded-md py-5 px-3 text-center">
            <p class="text-[11px] text-[#646464] uppercase tracking-[0.08em] font-bold mb-2">Altura total</p>
            <div class="text-[1.5rem] md:text-[1.75rem] font-bold text-[#DA291C] leading-none">1.860<span class="text-sm text-[#3B3938] ml-1">mm</span></div>
          </div>
          <div class="bg-[#F8F9FA] border border-[#E7E7E7] rounded-md py-5 px-3 text-center">
            <p class="text-[11px] text-[#646464] uppercase tracking-[0.08em] font-bold mb-2">Ancho total</p>
            <div class="text-[1.5rem] md:text-[1.75rem] font-bold text-[#DA291C] leading-none">1.921<span class="text-sm text-[#3B3938] ml-1">mm</span></div>
          </div>
        </div>
      </div>

      <!-- Capacidades internas -->
      <div class="mt-8 pt-8 border-t border-[#E7E7E7] grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-[1.75rem] font-bold text-[#3B3938] leading-none mb-1">4,4<span class="text-base text-[#DA291C] font-bold ml-1">m³</span></div>
          <p class="text-[11px] text-[#646464] uppercase tracking-wide font-bold">Volumen de carga</p>
        </div>
        <div class="text-center">
          <div class="text-[1.75rem] font-bold text-[#3B3938] leading-none mb-1">3,44<span class="text-base text-[#DA291C] font-bold ml-1">m</span></div>
          <p class="text-[11px] text-[#646464] uppercase tracking-wide font-bold">Longitud de carga</p>
        </div>
        <div class="text-center">
          <div class="text-[1.75rem] font-bold text-[#3B3938] leading-none mb-1">1.000<span class="text-base text-[#DA291C] font-bold ml-1">kg</span></div>
          <p class="text-[11px] text-[#646464] uppercase tracking-wide font-bold">Carga útil</p>
        </div>
        <div class="text-center">
          <div class="text-[1.75rem] font-bold text-[#3B3938] leading-none mb-1">3<span class="text-base text-[#DA291C] font-bold ml-1">plazas</span></div>
          <p class="text-[11px] text-[#646464] uppercase tracking-wide font-bold">Incluido conductor</p>
        </div>
      </div>
    </div>

  </div>
</section>
